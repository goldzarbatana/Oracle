<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEngine.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Template name="Sanctuary" src="project://database/Assets/Resources/UI/Oracle/SanctuaryUI.uxml?fileID=9197481963319205126&amp;guid=67fb9ce18882d9f4881baf934d44af0a&amp;type=3#SanctuaryUI"/>
    <Style src="project://database/Assets/Resources/UI/Nexus/NexusScene.uss?fileID=7433441132597879392&amp;guid=3ee0ef23c57fa2c4096a46ba201a93c1&amp;type=3#NexusScene"/>
    <Style src="project://database/Assets/Resources/UI/Nexus/RadarStyles.uss?fileID=7433441132597879392&amp;guid=8eb1a1db9fe812847ac8311d06c64095&amp;type=3#RadarStyles"/>
    <Style src="project://database/Assets/Resources/UI/Oracle/OracleWidget.uss?fileID=7433441132597879392&amp;guid=d15ffac0813b93740bd34cfe920a1c73&amp;type=3#OracleWidget"/>
    <Style src="project://database/Assets/Resources/UI/Nexus/HarmonyStyles.uss?fileID=7433441132597879392&amp;guid=bccdecba54fb50f44b0b0a78e23adbc3&amp;type=3#HarmonyStyles"/>
    <ui:VisualElement name="ScreenRoot" class="screen-container" style="width: 100%; height: 100%; flex-grow: 1; display: flex; opacity: 1;">
        <ui:VisualElement name="WelcomeRite" style="display: none; opacity: 0;">
            <ui:Label name="LblWelcomeText" text="✦ ЛАСКАВО ПРОСИМО ДО НЕКСУСУ ✦" style="color: white; font-size: 32px; letter-spacing: 8px; -unity-text-align: middle-center; -unity-text-auto-size: best-fit 10px 74px; -unity-text-generator: advanced; height: 1087px;"/>
        </ui:VisualElement>
        <ui:VisualElement name="PanelContent" class="content-area" style="width: 100%; height: 100%; flex-grow: 1;">
            <ui:VisualElement name="RadarPanel" class="panel radar-panel panel--hidden" style="display: none; opacity: 0; width: 100%; height: 100%; position: absolute; flex-direction: column;">
                <ui:VisualElement name="RadarBackground" picking-mode="Ignore" class="radar-background" style="height: 100%; width: 100%; position: absolute;"/>
                <ui:VisualElement style="flex-grow: 1; align-items: center; justify-content: center; width: 100%; height: 85%;">
                    <ui:VisualElement style="width: 75%; max-width: 400px;">
                        <ui:VisualElement style="width: 100%; padding-bottom: 100%;">
                            <ui:VisualElement name="ScannerArea" class="scanner-area" style="position: absolute; width: 100%; height: 100%; left: 0; top: 0;">
                                <ui:VisualElement name="ScryingOrbBase" class="scrying-orb-base" style="width: 150%; height: 151%;">
                                    <ui:VisualElement name="ScryingOrbSphere" class="scrying-orb-sphere" style="height: 400%;">
                                        <ui:VisualElement name="MistContainer" picking-mode="Ignore" class="mist-container"/>
                                    </ui:VisualElement>
                                    <ui:VisualElement name="ResonancePoints" picking-mode="Ignore" class="resonance-points-container" style="position: absolute; width: 100%; height: 100%;"/>
                                    <ui:VisualElement name="OrbPedestalImage" picking-mode="Ignore" class="scrying-orb-pedestal-image" style="height: 140%; bottom: -316px;"/>
                                </ui:VisualElement>
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="StatusOverlay" class="status-overlay" style="flex-shrink: 0; align-items: center; padding-bottom: 35%;">
                    <ui:Label text="READY TO SCRY" name="LblStatus" class="status-text" style="-unity-text-auto-size: best-fit 10px 60px; -unity-text-generator: advanced; -unity-text-align: middle-center;"/>
                    <ui:Label text="0 VISIONS" name="LblMatchCount" class="match-count" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 64px; margin-bottom: 30px;"/>
                    <ui:Button text="PEER INTO THE ORB" name="BtnToggleSearch" class="btn-toggle-search" style="-unity-background-scale-mode: stretch-to-fill; height: 11%; max-height: 120px; min-height: 80px; width: 80%; max-width: 400px; -unity-text-auto-size: best-fit 10px 103px; -unity-text-generator: advanced;"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="DiscoveryPanel" class="panel discovery-panel panel--hidden" style="align-items: stretch; justify-content: flex-start;">
                <ui:VisualElement class="discovery-container" style="flex-grow: 1; display: flex; flex-direction: column; width: 100%; height: 100%;">
                    <ui:ScrollView name="DiscoveryTabsScroll" mode="Horizontal" class="discovery-tabs-scroll" style="height: 60px; margin-bottom: 10px; flex-shrink: 0;">
                        <ui:VisualElement name="DiscoveryTabs" class="discovery-tabs" style="flex-direction: row; align-items: center; padding: 5px;"/>
                    </ui:ScrollView>
                    <ui:ScrollView name="DiscoveryFeed" class="discovery-feed" style="flex-grow: 1;">
                        <ui:VisualElement name="GridContainer" class="grid-container"/>
                    </ui:ScrollView>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="ChamberPanel" class="panel chamber-panel panel--hidden" style="opacity: 0; display: none;">
                <ui:Label text="THE CHAMBER" class="panel-title" style="margin-bottom: 5px; color: rgb(218, 165, 32); -unity-text-align: middle-center;"/>
                <ui:Label text="YOUR COVENANTS AND ARTIFACTS" class="panel-subtitle" style="margin-bottom: 20px; -unity-text-align: middle-center;"/>
                <ui:ScrollView class="chamber-scroll" style="flex-grow: 1; width: 100%;">
                    <ui:VisualElement class="chamber-section" style="flex-grow: 1;">
                        <ui:Label text="ACTIVE SESSIONS" class="chamber-section-title"/>
                        <ui:ScrollView name="ChamberActiveSessions" class="chamber-sessions-scroll" style="flex-grow: 1; min-height: 200px;">
                            <ui:VisualElement name="ChamberEmptyState" class="chamber-empty-state" style="align-items: center; justify-content: center; height: 100%; padding-top: 50px;">
                                <ui:Label text="🕸️" style="font-size: 80px; -unity-text-align: middle-center; opacity: 0.5;"/>
                                <ui:Label text="NO ACTIVE PACTS" style="color: rgba(255, 255, 255, 0.5); -unity-font-style: bold; margin-top: 10px; -unity-text-align: middle-center;"/>
                                <ui:Label text="Seek resonance in the Feed to form new covenants." style="color: rgba(255, 255, 255, 0.3); font-size: 12px; margin-top: 5px; white-space: normal; -unity-text-align: middle-center;"/>
                            </ui:VisualElement>
                        </ui:ScrollView>
                    </ui:VisualElement>
                    <ui:VisualElement class="chamber-section">
                        <ui:Label text="CHRONICLES OF POWER" class="chamber-section-title"/>
                        <ui:VisualElement class="chamber-stats-group" style="flex-direction: row; justify-content: space-around; background-color: rgba(0, 0, 0, 0.3); border-radius: 12px; padding: 15px; margin-top: 10px;">
                            <ui:VisualElement class="chamber-stat-box" style="align-items: center;">
                                <ui:Label text="ACTIVE PACTS" class="stat-label" style="font-size: 10px; color: rgba(255, 255, 255, 0.5); margin-bottom: 5px;"/>
                                <ui:Label name="LblChamberActivePacts" text="0" class="stat-value" style="font-size: 24px; color: rgb(212, 175, 55); -unity-font-style: bold;"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="chamber-stat-box" style="align-items: center;">
                                <ui:Label text="TOTAL HORAS" class="stat-label" style="font-size: 10px; color: rgba(255, 255, 255, 0.5); margin-bottom: 5px;"/>
                                <ui:Label name="LblChamberHoras" text="0" class="stat-value" style="font-size: 24px; color: rgb(212, 175, 55); -unity-font-style: bold;"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="chamber-stat-box" style="align-items: center;">
                                <ui:Label text="SYMMETRIES" class="stat-label" style="font-size: 10px; color: rgba(255, 255, 255, 0.5); margin-bottom: 5px;"/>
                                <ui:Label name="LblChamberSymmetries" text="0" class="stat-value" style="font-size: 24px; color: rgb(212, 175, 55); -unity-font-style: bold;"/>
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="chamber-section" style="margin-top: 20px;">
                        <ui:Label text="QUICK ACTIONS" class="chamber-section-title"/>
                        <ui:VisualElement class="chamber-actions-group" style="flex-direction: row; flex-wrap: wrap; justify-content: space-between; margin-top: 10px;">
                            <ui:Button name="BtnActionCreate" text="✦ FEED" class="chamber-action-btn" style="width: 48%; margin-bottom: 10px;"/>
                            <ui:Button name="BtnActionOracle" text="👁️ ORACLE" class="chamber-action-btn" style="width: 48%; margin-bottom: 10px;"/>
                            <ui:Button name="BtnActionVault" text="🛡️ VAULT" class="chamber-action-btn" style="width: 100%;"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:ScrollView>
            </ui:VisualElement>
            <ui:VisualElement name="SettingsPanel" class="panel settings-panel panel--hidden">
                <ui:Button name="BtnCloseSettingsTop" text="✕" style="position: absolute; top: 8%; right: 4%; background-color: transparent; border-width: 0; color: white; font-size: 80px; -unity-font-style: bold; padding: 0;"/>
                <ui:Label text="NEXUS SETTINGS" class="essence-header" style="margin-bottom: 80px; margin-top: 40px;"/>
                <ui:ScrollView class="settings-scroll">
                    <ui:VisualElement name="MenuLangSelector" class="carousel-container" style="margin-top: 0; height: 100px; margin-bottom: 20px;">
                        <ui:Label text="&lt;" class="carousel-arrow"/>
                        <ui:ScrollView name="LangCarousel" mode="Horizontal" show-horizontal-scroller="false" show-vertical-scroller="false" class="lang-carousel" style="flex-grow: 1; height: 100%;">
                            <ui:Button name="BtnLangUA" text="🇺🇦 UA" class="lang-btn lang-btn--active" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangEN" text="🇺🇸 EN" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangES" text="🇪🇸 ES" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangFR" text="🇫🇷 FR" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangDE" text="🇩🇪 DE" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangIT" text="🇮🇹 IT" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangPL" text="🇵🇱 PL" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangRU" text="🇷🇺 RU" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangTR" text="🇹🇷 TR" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnLangHI" text="🇮🇳 HI" class="lang-btn" style="flex-shrink: 0;"/>
                        </ui:ScrollView>
                        <ui:Label text="&gt;" class="carousel-arrow"/>
                    </ui:VisualElement>
                    <ui:Label text="ORACLE VOICE" class="menu-header" style="font-size: 12px; opacity: 0.5; margin-top: 10px; margin-bottom: 5px;"/>
                    <ui:VisualElement name="MenuPersonaSelector" class="carousel-container" style="margin-top: 0; height: 100px; margin-bottom: 20px;">
                        <ui:ScrollView name="PersonaScroll" mode="Horizontal" show-horizontal-scroller="false" show-vertical-scroller="false" class="lang-carousel" style="flex-grow: 1; height: 100%;">
                            <ui:Button name="BtnSidePersonaMystic" text="🌌" tooltip="Mystic" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnSidePersonaBusiness" text="💼" tooltip="Business" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnSidePersonaCasual" text="🎈" tooltip="Casual" class="lang-btn" style="flex-shrink: 0;"/>
                            <ui:Button name="BtnSidePersonaTech" text="🦾" tooltip="Tech" class="lang-btn" style="flex-shrink: 0;"/>
                        </ui:ScrollView>
                    </ui:VisualElement>
                    <ui:VisualElement class="settings-group">
                        <ui:Label text="AUDIO CHANNELS" class="section-label"/>
                        <ui:VisualElement class="setting-item">
                            <ui:Label text="MASTER VOLUME" class="setting-label"/>
                            <ui:Slider name="SliderMasterVol" low-value="0" high-value="1" value="1" class="aura-slider"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="setting-item">
                            <ui:Label text="MUSIC" class="setting-label"/>
                            <ui:Slider name="SliderMusicVol" low-value="0" high-value="1" value="0.7" class="aura-slider"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="setting-item">
                            <ui:Label text="EFFECTS (SFX)" class="setting-label"/>
                            <ui:Slider name="SliderSFXVol" low-value="0" high-value="1" value="0.8" class="aura-slider"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="setting-item">
                            <ui:Label text="AMBIENCE" class="setting-label"/>
                            <ui:Slider name="SliderAmbienceVol" low-value="0" high-value="1" value="0.5" class="aura-slider"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="setting-item">
                            <ui:Label text="UI SCALE" class="setting-label"/>
                            <ui:Slider name="SliderUIScale" low-value="0.8" high-value="1.3" value="1" class="aura-slider"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="setting-item setting-item--row">
                            <ui:Label text="SILENCE MODE (MUTE)" class="setting-label"/>
                            <ui:Toggle name="ToggleMute" class="aura-toggle"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:ScrollView>
                <ui:Button text="CLOSE" name="BtnCloseSettings" class="confirm-button" style="background-color: rgba(255, 255, 255, 0.05); margin-top: auto;"/>
                <ui:Label text="v1.0.0 (Adept Core)" name="LblAppVersion" style="-unity-text-align: middle-center; color: rgba(255, 255, 255, 0.3); font-size: 14px; margin-top: 15px; margin-bottom: 15px; -unity-font-style: bold;"/>
            </ui:VisualElement>
            <ui:VisualElement name="AuraPanel" class="panel essence-panel panel--hidden" style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; display: none; opacity: 0; background-color: rgba(5, 5, 12, 0.98); z-index: 1000; padding-top: 10%;">
                <ui:Button name="BtnCloseAura" text="✕" style="position: absolute; top: 30px; right: 30px; width: 50px; height: 50px; font-size: 24px; color: white; background-color: transparent; border-width: 0; -unity-font-style: bold;"/>
                <ui:VisualElement class="aura-container" style="padding-top: 6%; padding-bottom: 5%;">
                    <ui:VisualElement class="aura-header-group" style="align-items: auto; align-content: auto; width: 100%; height: 15%;">
                        <ui:Label text="RESONATE YOUR AURA" name="AuraHeader" class="essence-header" style="-unity-text-auto-size: best-fit 10px 100px; align-self: stretch; margin-bottom: 30px; width: 100%; height: 25%;"/>
                        <ui:VisualElement name="AuraTabs" class="aura-tabs" style="height: 100%; align-self: auto; align-content: auto; -unity-text-align: upper-center; -unity-text-auto-size: best-fit 10px 100px; -unity-text-generator: advanced; align-items: auto;">
                            <ui:Button name="BtnTabUnified" text="ОБ&apos;ЄДНАНО" class="aura-tab-btn aura-tab-btn--active" style="-unity-text-auto-size: best-fit 6px 100px; align-items: auto; align-content: auto; width: 50%; height: 75%;"/>
                            <ui:Button name="BtnTabCompass" text="COMPASS" class="aura-tab-btn" style="-unity-text-auto-size: best-fit 10px 100px; width: 50%; align-items: auto; align-content: auto; height: 75%;"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement name="ActiveSelectionContainer" class="active-tags-container" style="height: 20%; width: 100%; margin-bottom: 0; padding-bottom: 0; padding-top: 0;">
                        <ui:VisualElement name="SelectedTagsList" class="tags-cloud" style="align-content: auto; align-items: auto; flex-direction: row; flex-wrap: nowrap; justify-content: flex-start; align-self: auto; height: auto;"/>
                        <ui:VisualElement name="HarmonyIndicator" class="harmony-indicator" style="height: 13%;">
                            <ui:VisualElement name="ManifestationFill" class="harmony-fill manifestation-fill" style="-unity-text-align: middle-left; -unity-text-auto-size: best-fit 10px 100px; -unity-text-generator: advanced; width: 100%;"/>
                            <ui:VisualElement name="IntentFill" class="harmony-fill intent-fill" style="width: 100%; height: 100%;"/>
                        </ui:VisualElement>
                        <ui:Label name="LblHarmonyValue" text="MANIFESTATION: 0% | INTENT: 0%" class="harmony-value-label" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 52px; -unity-text-align: middle-center; width: 100%; height: 25%;"/>
                    </ui:VisualElement>
                    <ui:ScrollView name="ScrollContainer" class="scroll-container" style="flex-grow: 1; margin-top: 10px;">
                        <ui:VisualElement name="TabContentUnified" class="essence-section" style="flex-direction: column; width: 100%; padding-bottom: 40px;">
                            <ui:Label name="LblGifts" text="🎁 Я ПРОПОНУЮ (МОЖУ)" class="section-label" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 32px; color: rgb(212, 175, 55);"/>
                            <ui:ScrollView name="ManifestPillarSelector" mode="Horizontal" show-horizontal-scroller="false" class="pillar-selector" style="height: 60px; min-height: 60px; margin-top: 10px; margin-bottom: 10px;"/>
                            <ui:VisualElement name="GiftsContainer" class="tags-cloud" style="align-self: stretch;"/>
                            <ui:Label name="LblSeeks" text="🔍 Я ШУКАЮ (ХОЧУ)" class="section-label" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 33px; color: rgb(0, 255, 255); margin-top: 30px;"/>
                            <ui:ScrollView name="IntentPillarSelector" mode="Horizontal" show-horizontal-scroller="false" class="pillar-selector" style="height: 60px; min-height: 60px; margin-top: 10px; margin-bottom: 10px;"/>
                            <ui:VisualElement name="SeeksContainer" class="tags-cloud"/>
                            <ui:VisualElement name="OracleEquipSection" class="oracle-equip-section" style="margin-top: 30px; margin-bottom: 20px; align-items: center;">
                                <ui:Label text="ОРАКУЛ-СУПУТНИК" name="LblOracleSectionTitle" class="section-label oracle-section-label"/>
                                <ui:VisualElement name="OracleSlot" class="oracle-slot oracle-slot--empty">
                                    <ui:VisualElement name="OracleSlotGlow" class="oracle-slot-glow"/>
                                    <ui:VisualElement name="OracleSlotIcon" class="oracle-slot-icon" style="display: none;"/>
                                    <ui:Label name="LblOracleSlotHint" text="⬡" class="oracle-slot-hint"/>
                                    <ui:Label name="LblOracleName" text="" class="oracle-slot-name"/>
                                </ui:VisualElement>
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement name="TabContentCompass" class="essence-section" style="display: none;">
                            <ui:Label name="LblSacredCompass" text="SACRED COMPASS (FILTERS)" class="section-label" style="color: rgb(212, 175, 55); margin-bottom: 20px; -unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 100px;"/>
                            <ui:VisualElement class="filter-item" style="flex-direction: row; align-items: center; margin-bottom: 20px;">
                                <ui:Label name="LblAgeRangeTag" text="AGE RANGE:" style="width: 30%; color: white; opacity: 0.7; font-size: 14px;"/>
                                <ui:SliderInt name="SliderMinAge" low-value="18" high-value="99" value="18" class="aura-slider" style="flex-grow: 1;"/>
                                <ui:Label name="LblMinAge" text="18" style="width: 40px; color: rgb(212, 175, 55); -unity-text-align: middle-right; font-size: 16px;"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="filter-item" style="flex-direction: row; align-items: center; margin-bottom: 20px;">
                                <ui:Label name="LblToTag" text="TO:" style="width: 30%; color: white; opacity: 0.7; font-size: 14px;"/>
                                <ui:SliderInt name="SliderMaxAge" low-value="18" high-value="99" value="99" class="aura-slider" style="flex-grow: 1;"/>
                                <ui:Label name="LblMaxAge" text="99" style="width: 40px; color: rgb(212, 175, 55); -unity-text-align: middle-right; font-size: 16px;"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="filter-item" style="flex-direction: row; align-items: center; margin-bottom: 30px;">
                                <ui:Label name="LblDistanceTag" text="DISTANCE (KM):" style="width: 30%; color: white; opacity: 0.7; font-size: 14px;"/>
                                <ui:Slider name="SliderDistance" low-value="1" high-value="500" value="50" class="aura-slider" style="flex-grow: 1;"/>
                                <ui:Label name="LblDistance" text="50" style="width: 40px; color: rgb(212, 175, 55); -unity-text-align: middle-right; font-size: 16px;"/>
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:ScrollView>
                    <ui:VisualElement class="footer-actions" style="position: relative; bottom: auto; left: auto; right: auto; margin-bottom: 2%; background-color: transparent; border-top-width: 0; height: 8%; width: 100%;">
                        <ui:Button text="MYSTICAL REFINEMENT" name="BtnRefineAura" class="confirm-button" style="display: none;"/>
                        <ui:Button text="SEAL THE AURA" name="BtnConfirmAura" class="confirm-button" style="display: none;"/>
                        <ui:Button text="BACK" name="BtnEditAura" class="confirm-button confirm-button--cancel" style="display: none;"/>
                        <ui:Button text="ШУКАТИ" name="BtnLaunchResonance" class="confirm-button" style="background-color: rgb(212, 175, 55); color: rgb(5, 5, 5); width: 59%; align-items: center; align-self: center; height: 180%; padding-bottom: 10px; -unity-text-auto-size: best-fit 10px 58px; margin-bottom: 12px;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="OracleSelectionModal" class="modal-overlay modal--hidden" style="display: none;">
                    <ui:VisualElement class="modal-content oracle-modal-content">
                        <ui:Label text="ОБЕРІТЬ ОРАКУЛА" name="LblOracleModalHeader" class="modal-header"/>
                        <ui:Label name="LblResonanceHint" text="Резонанс розраховано на основі ваших дарів" class="modal-text"/>
                        <ui:ScrollView name="OracleListScroll" class="oracle-list-scroll">
                            <ui:VisualElement name="OracleListContainer" class="oracle-list-container"/>
                        </ui:ScrollView>
                        <ui:Button name="BtnGenerateOracle" text="Створити кастомного Оракула під твої таланти" class="modal-btn modal-btn--gold" style="margin-bottom: 12px;"/>
                        <ui:Button name="BtnCloseOracleModal" text="ЗАКРИТИ" class="modal-btn"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="SupportModal" class="modal-overlay modal--hidden">
                <ui:VisualElement class="modal-content">
                    <ui:Label name="LblSupportHeader" text="SUPPORT TIME AURA" class="modal-header" style="color: rgb(212, 175, 55);"/>
                    <ui:Label name="LblSupportText" text="Choose how to send energy to the creators." class="modal-text" style="margin-bottom: 30px;"/>
                    <ui:Button name="BtnSupportAd" text="VIEW A VISION (AD)" class="modal-btn" style="margin-bottom: 15px;"/>
                    <ui:Button name="BtnSupportDonate" text="SHARE RESOURCES ($1)" class="modal-btn modal-btn--gold" style="margin-bottom: 30px;"/>
                    <ui:Button name="BtnSupportClose" text="CLOSE" class="modal-btn" style="background-color: rgba(255, 255, 255, 0.05);"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:Instance template="Sanctuary" name="SanctuaryPanel" class="panel panel--hidden" style="display: none; opacity: 0; height: 90%; top: -100px; bottom: 0;"/>
