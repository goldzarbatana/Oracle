                        <ui:VisualElement class="scales-arm scales-arm--right">
                            <ui:VisualElement name="ScalesChainRight" class="scales-chain"/>
                            <ui:VisualElement name="ScalesPanRight" class="scales-pan">
                                <ui:VisualElement name="HorasCoinsContainer" class="horas-coins-container"/>
                                <ui:Label name="LblHorasCount" text="?" class="scales-horas-count" style="-unity-text-generator: advanced;"/>
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement name="ScalesPedestal" class="scales-pedestal"/>
                </ui:VisualElement>
                <ui:VisualElement name="VerdictContainer" class="scales-verdict-container" style="opacity: 0;">
                    <ui:Label name="LblVerdict" text="" multiline="true" class="scales-verdict-text" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 20px;"/>
                </ui:VisualElement>
                <ui:VisualElement name="ScalesActions" class="scales-actions" style="opacity: 0;">
                    <ui:Button name="BtnAcceptEvaluation" text="✦ ПРИЙНЯТИ ОЦІНКУ" class="modal-btn modal-btn--gold scales-btn-accept" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 22px;"/>
                    <ui:Button name="BtnManualHoras" text="◈ ПРИЗНАЧИТИ ВРУЧНУ" class="modal-btn modal-btn--outline scales-btn-manual" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 18px;"/>
                    <ui:Button name="BtnCancelScales" text="СКАСУВАТИ" class="modal-btn modal-btn--ghost" style="-unity-text-generator: advanced; -unity-text-auto-size: best-fit 10px 16px;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="EscrowModal" class="modal-overlay modal--hidden">
            <ui:VisualElement class="modal-content">
                <ui:Label text="РИТУАЛ ЕСКРОУ" class="modal-header"/>
                <ui:Label text="Заморозьте час у ефірі для забезпечення вашої домовленості." class="modal-text"/>
                <ui:VisualElement style="flex-direction: row; justify-content: space-between; width: 100%;">
                    <ui:TextField name="InputEscrowHours" label="ХОРАСИ (ГОД)" class="modal-input" style="flex: 1; margin-right: 10px;"/>
                    <ui:TextField name="InputEscrowMinutes" label="АТОМИ (ХВИЛ)" class="modal-input" style="flex: 1; margin-left: 10px;"/>
                </ui:VisualElement>
                <ui:VisualElement style="flex-direction: row; margin-top: 40px;">
                    <ui:Button name="BtnConfirmEscrow" text="ЗАПЕЧАТАТИ ЧАС" class="modal-btn modal-btn--gold"/>
                    <ui:Button name="BtnCancelEscrow" text="СКАСУВАТИ" class="modal-btn"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="GratitudeModal" class="modal-overlay modal--hidden">
            <ui:VisualElement class="modal-content">
                <ui:Label text="WORD OF GRATITUDE" class="modal-header"/>
                <ui:Label text="Leave a brief legacy for your partner (20 chars)." class="modal-text"/>
                <ui:TextField name="InputGratitude" max-length="20" class="modal-input"/>
                <ui:Button name="BtnSendGratitude" text="SEAL LEGACY" class="modal-btn modal-btn--gold"/>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="CreatePostModal" class="modal-overlay modal--hidden" style="display: none;">
            <ui:VisualElement class="modal-content" style="width: 90%; max-width: 650px;">
                <ui:Label text="НОВИЙ ЗАПИТ" class="modal-header" style="-unity-font-style: bold;"/>
                <ui:Label text="Опишіть вашу потребу та виберіть сферу" class="modal-text"/>
                <ui:TextField name="InputPostContent" label="ОПИС" multiline="true" class="modal-input" style="min-height: 120px; margin-bottom: 15px;"/>
                <ui:Label text="СФЕРА ОБМІНУ" class="stat-label" style="align-self: flex-start; margin-top: 5px; color: rgb(212, 175, 55);"/>
                <ui:VisualElement name="ModalRealmSelector" style="flex-direction: row; width: 100%; margin-bottom: 15px;">
                    <ui:Button name="BtnModalEther" text="🌌 БАРТЕР (ХОРИ)" class="modal-btn modal-btn--gold" style="flex: 1; margin-right: 5px;"/>
                    <ui:Button name="BtnModalMatter" text="💵 ФІАТ (USD)" class="modal-btn" style="flex: 1; margin-left: 5px;"/>
                </ui:VisualElement>
                <ui:VisualElement style="flex-direction: row; justify-content: space-between; width: 100%; margin-bottom: 15px;">
                    <ui:TextField name="InputPostPrice" label="ЦІНА" class="modal-input" style="flex: 1; margin-right: 5px;"/>
                    <ui:DropdownField name="DropdownPostCategory" label="КАТЕГОРІЯ" class="modal-input" style="flex: 1; margin-left: 5px;"/>
                </ui:VisualElement>
                <ui:VisualElement name="LocationSearchContainer" style="width: 100%; margin-bottom: 25px;">
                    <ui:Label text="ЛОКАЦІЯ / МІСТО" class="modal-input" style="color: rgb(212, 175, 55); font-size: 13px; -unity-font-style: bold; margin-bottom: 6px; align-self: flex-start;"/>
                    <ui:VisualElement style="flex-direction: row; width: 100%; margin-bottom: 6px;">
                        <ui:TextField name="InputLocationSearch" placeholder-text="Пошук міста або Online..." class="modal-input" style="flex: 1; margin-right: 8px; margin-bottom: 0;"/>
                        <ui:Button name="BtnLocationOnline" text="🌐 Online" class="modal-btn" style="width: 90px; flex-shrink: 0; font-size: 12px; height: 48px; padding: 0 8px;"/>
                    </ui:VisualElement>
                    <ui:Label name="LblSelectedLocation" text="" style="color: rgb(150, 220, 150); font-size: 12px; margin-bottom: 4px; display: none;"/>
                    <ui:ScrollView name="LocationResultsList" style="max-height: 150px; background-color: rgba(10, 10, 20, 0.95); border-width: 1px; border-color: rgba(212, 175, 55, 0.4); border-radius: 8px; display: none;"/>
                </ui:VisualElement>
                <ui:VisualElement style="flex-direction: row; justify-content: space-between; width: 100%;">
                    <ui:Button name="BtnConfirmPost" text="ОПУБЛІКУВАТИ" class="modal-btn modal-btn--gold" style="flex: 1; margin-right: 10px;"/>
                    <ui:Button name="BtnCancelPost" text="СКАСУВАТИ" class="modal-btn" style="flex: 1; margin-left: 10px;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="OracleIntentModal" class="modal-overlay modal--hidden" style="display: none;">
            <ui:VisualElement class="modal-content" style="width: 90%; max-width: 650px;">
                <ui:Label text="ОРАКУЛ БАЖАНЬ" class="modal-header" style="-unity-font-style: bold;"/>
                <ui:Label text="Промовте або введіть бажання для створення запиту" class="modal-text"/>
                <ui:VisualElement style="flex-direction: row; align-items: center; width: 100%; margin-bottom: 20px;">
                    <ui:TextField name="InputIntentText" placeholder-text="Я хочу навчитись грі на гітарі за 2 хори..." multiline="true" class="modal-input" style="flex: 1; margin-right: 10px; height: 60px;"/>
                    <ui:Button name="BtnRecordVoice" text="🎙️" class="modal-btn" style="width: 50px; height: 50px; border-radius: 25px; font-size: 20px; align-self: center; justify-content: center; padding: 0; margin: 0;"/>
                </ui:VisualElement>
                <ui:VisualElement style="flex-direction: row; justify-content: space-between; width: 100%;">
                    <ui:Button name="BtnSubmitIntent" text="🔮 ЗАПРОСИТИ ШІ" class="modal-btn modal-btn--gold" style="flex: 1.5; margin-right: 5px;"/>
                    <ui:Button name="BtnSwitchToManual" text="✍️ ВРУЧНУ" class="modal-btn" style="flex: 1; margin-left: 5px; margin-right: 5px;"/>
                    <ui:Button name="BtnCloseIntent" text="СКАСУВАТИ" class="modal-btn" style="flex: 1; margin-left: 5px;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="OracleEyeRoot" picking-mode="Position" class="oracle-eye-root oracle-eye--closed">
            <ui:VisualElement name="EyeContainer" picking-mode="Ignore" class="oracle-eye-container">
                <ui:VisualElement name="Pupil" class="oracle-eye-pupil"/>
                <ui:VisualElement name="LidTop" class="oracle-eye-lid oracle-eye-lid--top"/>
                <ui:VisualElement name="LidBottom" class="oracle-eye-lid oracle-eye-lid--bottom"/>
            </ui:VisualElement>
            <ui:VisualElement name="HintBubble" class="hint-bubble">
                <ui:Label name="HintLabel" text="The threads of time are weaving..." class="hint-text"/>
            </ui:VisualElement>
            <ui:VisualElement name="GeminiChatOverlay" picking-mode="Position" class="chat-overlay chat-overlay--hidden">
                <ui:VisualElement class="chat-header">
                    <ui:Label text="ORACLE WISDOM" class="chat-title"/>
                    <ui:Button name="BtnCloseChat" text="×" class="chat-close-btn"/>
                </ui:VisualElement>
                <ui:ScrollView name="ChatScrollView" class="chat-messages">
                    <ui:Label text="I am listening to the whispers of the Nexus..." class="chat-message chat-message--oracle"/>
                </ui:ScrollView>
                <ui:VisualElement class="chat-input-area" style="align-items: auto; justify-content: space-between;">
                    <ui:TextField name="InputChat" placeholder-text="Ask the Oracle..." class="chat-input"/>
                    <ui:Button name="BtnSendChat" text="➤" class="chat-send-btn"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:Label name="PanelTitleToast" text="SANCTUARY" picking-mode="Ignore" class="panel-toast" style="height: 5%; width: 100%; padding-top: 5px; padding-bottom: 5px; align-self: stretch; justify-content: center; right: auto; left: auto;"/>
        <ui:VisualElement name="DeveloperAdminPanel" class="modal-overlay modal--hidden" style="display: none; background-color: rgba(5, 5, 12, 0.98); align-items: center; justify-content: center; position: absolute; width: 100%; height: 100%; top: 0; left: 0;">
            <ui:VisualElement class="modal-content" style="width: 90%; max-width: 600px; height: 80%; background-color: rgba(10, 10, 20, 0.98); border-color: rgb(212, 175, 55); border-width: 1px; border-radius: 12px; padding: 25px;">
                <ui:Label text="NEXUS CORE: REMOTE ARCHIVE (ADMIN)" style="font-size: 20px; color: rgb(212, 175, 55); -unity-font-style: bold; margin-bottom: 15px; -unity-text-align: middle-center;"/>
                <ui:ScrollView name="AdminConfigList" style="flex-grow: 1; margin-bottom: 15px; background-color: rgba(0, 0, 0, 0.3); padding: 10px; border-radius: 8px;"/>
                <ui:VisualElement style="flex-direction: row; justify-content: space-between; flex-shrink: 0;">
                    <ui:Button name="BtnAdminReload" text="RELOAD FROM SHEETS" class="modal-btn modal-btn--gold" style="width: 48%; margin: 0;"/>
                    <ui:Button name="BtnAdminClose" text="CLOSE CORE" class="modal-btn" style="width: 48%; background-color: rgba(255, 255, 255, 0.05); margin: 0;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
