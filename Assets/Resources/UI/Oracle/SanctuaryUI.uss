/* --- Quick Prompts --- */
.quick-prompts-scroll {
    height: 60px;
    margin-bottom: 15px;
    flex-shrink: 0;
}

.quick-prompt-btn {
    background-color: rgba(212, 175, 55, 0.1);
    border-width: 1px;
    border-color: rgba(212, 175, 55, 0.3);
    border-radius: 20px;
    color: var(--gold);
    padding: 10px 20px;
    margin-right: 10px;
    font-size: 14px;
    transition-duration: 0.2s;
}

.quick-prompt-btn:hover {
    background-color: rgba(212, 175, 55, 0.2);
    scale: 1.05;
}

/* --- Interactive Notifications --- */
.interactive-action-btn {
    background-color: var(--gold);
    color: black;
    border-radius: 12px;
    padding: 10px 20px;
    margin-top: 10px;
    align-self: center;
    -unity-font-style: bold;
    font-size: 14px;
}

.interactive-action-btn:hover {
    scale: 1.05;
}

.chat-voice-btn {
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.05);
    background-image: url('project://database/Assets/Sprite/Microphone.png');
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: white;
    border-color: rgba(212, 175, 55, 0.2);
    border-width: 1px;
    border-radius: 20px;
    color: white;
    font-size: 18px;
    transition-duration: 0.15s;
    justify-content: center;
    align-items: center;
    padding: 8px; /* padding so the icon doesn't touch the borders */
    margin: 0;
}

.chat-voice-btn:hover {
    color: var(--gold);
    border-color: var(--gold);
    -unity-background-image-tint-color: var(--gold);
    scale: 1.05;
}

.chat-voice-btn--recording {
    background-color: rgba(212, 175, 55, 0.25);
    border-color: #D4AF37;
    scale: 1.15;
}
