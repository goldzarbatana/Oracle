<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:Style src="GeminiChatOverlay.uss" />
    <ui:VisualElement name="GeminiChatOverlay" class="chat-overlay chat-overlay--hidden" picking-mode="Position">
        <ui:VisualElement class="chat-header">
            <ui:Label text="ORACLE WISDOM" class="chat-title"/>
            <ui:Button name="BtnCloseChat" text="×" class="chat-close-btn"/>
        </ui:VisualElement>
        
        <ui:ScrollView name="ChatScrollView" class="chat-messages">
            <ui:Label text="I am listening to the whispers of the Nexus..." class="chat-message chat-message--oracle"/>
        </ui:ScrollView>
        
        <ui:VisualElement class="chat-input-area">
            <ui:TextField name="InputChat" placeholder-text="Ask the Oracle..." class="chat-input"/>
            <ui:Button name="BtnSendChat" text="➤" class="chat-send-btn"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
