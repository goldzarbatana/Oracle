    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569605
    m_Localized: "\u041E\u0436\u0438\u0434\u0430\u043D\u0438\u0435 \u0430\u0443\u0442\u0435\u043D\u0442\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
      \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569606
    m_Localized: "\u0414\u0432\u0435\u0440\u044C \u043E\u0442\u043A\u0440\u044B\u0442\u0430,
      \u0437\u0430\u0445\u043E\u0434\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971616763904
    m_Localized: "\u041E\u0416\u0418\u0414\u0410\u041D\u0418\u0415_\u0425\u0415\u041D\u0414\u0428\u0415\u0419\u041A\u0410_\u041A\u041B\u0418\u0415\u041D\u0422\u0410..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958208
    m_Localized: "\u041F\u0443\u0442\u044C \u0442\u0440\u0435\u0431\u0443\u0435\u0442
      \u0431\u043E\u043B\u0435\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
      \u0432\u0438\u0431\u0440\u0430\u0446\u0438\u0438..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958209
    m_Localized: "\u041D\u0435\u0434\u043E\u043F\u0443\u0441\u0442\u0438\u043C\u044B\u0439
      \u0432\u0432\u043E\u0434. \u041C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u0430\u044F
      \u0434\u043B\u0438\u043D\u0430 \u043D\u0435 \u0441\u043E\u0431\u043B\u044E\u0434\u0435\u043D\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958210
    m_Localized: "\u041E\u0439, \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043A\u043E\u0440\u043E\u0442\u043A\u043E!
      \u0414\u043E\u0431\u0430\u0432\u044C \u0435\u0449\u0435 \u0446\u0438\u0444\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958211
    m_Localized: "\u041E\u0428\u0418\u0411\u041A\u0410_\u041D\u0415\u0414\u041E\u0421\u0422\u0410\u0422\u041E\u0427\u041D\u0410\u042F_\u0414\u041B\u0418\u041D\u0410_\u0412\u0412\u041E\u0414\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958212
    m_Localized: "\u041F\u0420\u0418\u0417\u042B\u0412 \u0421\u0418\u041C\u041C\u0415\u0422\u0420\u0418\u0418..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958213
    m_Localized: "\u041F\u041E\u0414\u041A\u041B\u042E\u0427\u0415\u041D\u0418\u0415
      \u041A \u0421\u0415\u0422\u0418..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958214
    m_Localized: "\u0414\u0435\u0440\u0436\u0438\u0441\u044C, \u043F\u043E\u0447\u0442\u0438
      \u0433\u043E\u0442\u043E\u0432\u043E..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958215
    m_Localized: "\u0418\u041D\u0418\u0426\u0418\u0410\u041B\u0418\u0417\u0410\u0426\u0418\u042F_\u042F\u0414\u0415\u0420\u041D\u042B\u0425_\u0421\u0415\u0420\u0412\u0418\u0421\u041E\u0412..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958216
    m_Localized: "\u0417\u0432\u0435\u0437\u0434\u044B \u043D\u0435 \u0441\u043E\u0448\u043B\u0438\u0441\u044C.
      \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435 \u0441\u043D\u043E\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958217
    m_Localized: "\u0421\u0431\u043E\u0439 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F.
      \u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430, \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
      \u0441\u043D\u043E\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958218
    m_Localized: "\u0427\u0442\u043E-\u0442\u043E \u043F\u043E\u0448\u043B\u043E
      \u043D\u0435 \u0442\u0430\u043A. \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439
      \u0435\u0449\u0435 \u0440\u0430\u0437!"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958219
    m_Localized: "\u041E\u0428\u0418\u0411\u041A\u0410_\u0422\u0410\u0419\u041C\u0410\u0423\u0422_\u0425\u0415\u041D\u0414\u0428\u0415\u0419\u041A\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958220
    m_Localized: "\u041A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u043D\u0438\u0442\u044C \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C.
      \u041F\u0435\u0440\u0435\u043F\u043E\u0434\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u0441\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958221
    m_Localized: "\u041A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
      \u043E\u0448\u0438\u0431\u043A\u0430. \u0421\u0432\u044F\u0436\u0438\u0442\u0435\u0441\u044C
      \u0441 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u043E\u0439 \u0438\u043B\u0438
      \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435 \u0441\u043D\u043E\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958222
    m_Localized: "\u0422\u0443\u0442 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0439
      \u0433\u043B\u044E\u043A! \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439
      \u0435\u0449\u0435 \u0440\u0430\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958223
    m_Localized: "\u041A\u0420\u0418\u0422\u0418\u0427\u0415\u0421\u041A\u0410\u042F_\u0421\u0418\u0421\u0422\u0415\u041C\u041D\u0410\u042F_\u041E\u0428\u0418\u0411\u041A\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971650318336
    m_Localized: "\u0420\u0435\u0437\u043E\u043D\u0430\u043D\u0441 \u0434\u0443\u0448\u0438
      \u0432 \u044D\u0444\u0438\u0440\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971650318337
    m_Localized: "\u041E\u0436\u0438\u0434\u0430\u043D\u0438\u0435 \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0433\u043E
      \u0434\u044B\u0445\u0430\u043D\u0438\u044F..."
    m_Metadata:
      m_Items: []
