    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836609
    m_Localized: "\u0418\u0421\u041F\u041E\u041B\u041D\u0418\u0422\u0415\u041B\u042C\u041D\u042B\u0415
      \u0418\u041D\u0421\u0410\u0419\u0422\u042B"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836610
    m_Localized: "\u0410\u041D\u0410\u041B\u0418\u0417 \u042F\u0414\u0420\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836611
    m_Localized: "\u041A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
      \u043F\u043E\u0442\u043E\u043A\u0438 \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u044B.
      \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435 \u043F\u043E\u0437\u0436\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836612
    m_Localized: "\u0417\u0432\u0435\u0437\u0434\u044B \u043E\u043A\u0443\u0442\u0430\u043D\u044B
      \u0442\u0435\u043D\u044C\u044E. \u041F\u043E\u0434\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u0441\u044C
      \u0441\u043D\u043E\u0432\u0430, \u043A\u043E\u0433\u0434\u0430 \u043F\u043E\u0442\u043E\u043A\u0438
      \u043F\u0440\u043E\u044F\u0441\u043D\u044F\u0442\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836613
    m_Localized: "\u0421\u0435\u0442\u0435\u0432\u043E\u0435 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435
      \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E. \u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
      \u0432\u043E\u0437\u043E\u0431\u043D\u043E\u0432\u0438\u0442\u0435 \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0430\u0446\u0438\u044E
      \u043F\u043E\u0437\u0436\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836614
    m_Localized: "\u041E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u0430 \u043F\u043E\u0442\u0435\u0440\u044F
      \u043F\u0430\u043A\u0435\u0442\u043E\u0432 \u0432 \u042D\u0444\u0438\u0440\u0435.
      \u041E\u0448\u0438\u0431\u043A\u0430 \u0440\u0443\u043A\u043E\u043F\u043E\u0436\u0430\u0442\u0438\u044F.
      \u041F\u043E\u0432\u0442\u043E\u0440\u0438\u0442\u0435 \u043F\u043E\u0437\u0436\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836615
    m_Localized: "\u0417\u0420\u0415\u041D\u0418\u0415"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836616
    m_Localized: "\u0421\u0412\u042F\u0422\u0418\u041B\u0418\u0429\u0415 \u041E\u0420\u0410\u041A\u0423\u041B\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836617
    m_Localized: "\u0412\u042B\u0419\u0422\u0418 \u0418\u0417 \u0422\u0418\u0428\u0418\u041D\u042B"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030912
    m_Localized: "\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0442\u0438\u0448\u0438\u043D\u0430
      \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u0430. \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
      \u043F\u043E\u0437\u0436\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030913
    m_Localized: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0441\u0442\u0438\u043B\u044C
      \u0440\u0435\u0437\u043E\u043D\u0430\u043D\u0441\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030914
    m_Localized: "\u041A\u0430\u043A\u043E\u0439 \u043F\u0443\u0442\u044C \u0448\u0435\u043F\u0447\u0435\u0442
      \u0432\u0430\u0448\u0430 \u0434\u0443\u0448\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030915
    m_Localized: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0441\u0432\u043E\u0439
      \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
      \u0442\u043E\u043D \u043E\u0431\u0449\u0435\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030916
    m_Localized: "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u0442\u0435 \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B
      \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030917
    m_Localized: "\u041A\u0430\u043A \u043D\u0430\u043C \u043E\u0431\u0449\u0430\u0442\u044C\u0441\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030918
    m_Localized: "\u0412\u0430\u0448\u0430 \u0432\u0438\u0431\u0440\u0430\u0446\u0438\u044F
      \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0435\u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030919
    m_Localized: "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438 \u043F\u0440\u043E\u0444\u0438\u043B\u044F
      \u0443\u0441\u043F\u0435\u0448\u043D\u043E \u0441\u0438\u043D\u0445\u0440\u043E\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030920
    m_Localized: "\u041F\u0440\u043E\u0442\u043E\u043A\u043E\u043B \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0430
      \u043E\u0431\u043D\u043E\u0432\u043B\u0435\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030921
    m_Localized: "\u041F\u043E\u043D\u044F\u043B! \u041C\u0435\u043D\u0456 \u0441\u0442\u0438\u043B\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030922
    m_Localized: "\u0428\u0430\u0433\u043D\u0438\u0442\u0435 \u0432 \u043F\u043E\u0442\u043E\u043A
