      m_Items: []
  - m_Id: 22520519346978816
    m_Localized: "ZATWIERD\u0179 ZMIANY"
    m_Metadata:
      m_Items: []
  - m_Id: 22520519372144640
    m_Localized: "WYKONAJ_SEKWENCJ\u0118_AUTORYZACJI"
    m_Metadata:
      m_Items: []
  - m_Id: 22520519372144642
    m_Localized: "ZALOGUJ SI\u0118"
    m_Metadata:
      m_Items: []
  - m_Id: 22520519372144646
    m_Localized: LECIMY!
    m_Metadata:
      m_Items: []
  - m_Id: 24516584153645056
    m_Localized: SYNERGIA
    m_Metadata:
      m_Items: []
  - m_Id: 24516584191393792
    m_Localized: CHILLIN
    m_Metadata:
      m_Items: []
  - m_Id: 24516584191393793
    m_Localized: SYNC_PROCESU
    m_Metadata:
      m_Items: []
  - m_Id: 24516584191393794
    m_Localized: NETWORKING
    m_Metadata:
      m_Items: []
  - m_Id: 24516584191393795
    m_Localized: "M\xD3J VIBE"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584195588096
    m_Localized: "DANE_U\u017BYTKOWNIKA"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336832
    m_Localized: LOGOWANIE_SYSTEMU
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336833
    m_Localized: PROSPEKTY
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336834
    m_Localized: KTO JEST BLISKO?
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336835
    m_Localized: SKANER
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336836
    m_Localized: GOTOWY DO NETWORKINGU
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336837
    m_Localized: "KTO JEST W \u041F\u041E\u0411\u041B\u0418\u0417\u0423?"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336838
    m_Localized: "SKANOWANIE CZ\u0118STOTLIWO\u015ACI"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336839
    m_Localized: "POSZUKIWANIE AKTYW\xD3W..."
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336840
    m_Localized: SZUKAM VIBE'U...
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336841
    m_Localized: PARSOWANIE DANYCH WIDMOWYCH...
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336842
    m_Localized: "PO\u0141\u0104CZ"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336843
    m_Localized: "POWIEDZ CZE\u015A\u0106"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336844
    m_Localized: UPLINK
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336845
    m_Localized: "MISTYCZNY G\u0141OS"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336846
    m_Localized: "G\u0141OS BIZNESOWY"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336847
    m_Localized: "LU\u0179NY G\u0141OS"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336848
    m_Localized: "G\u0141OS TECH"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336849
    m_Localized: ZDEFINIUJ KLUCZOWE KOMPETENCJE
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336850
    m_Localized: POKAZ SWOJ VIBE
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336851
    m_Localized: "SKONFIGURUJ MACIERZ ATRYBUT\xD3W"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584237531136
    m_Localized: GOTOWE!
    m_Metadata:
      m_Items: []
  - m_Id: 25083740322889728
    m_Localized: USTAWIENIA NEXUS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832768
    m_Localized: "G\u0141O\u015ANO\u015A\u0106 G\u0141\xD3WNA"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832769
    m_Localized: MUZYKA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832770
    m_Localized: EFEKTY (SFX)
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832771
    m_Localized: AMBIENT
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832772
    m_Localized: WYCISZ WSZYSTKO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832773
    m_Localized: WITAJ W NEXUS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832774
    m_Localized: TWOJA AKTUALNA AURA...
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832775
    m_Localized: MOJE DARY
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832776
    m_Localized: SZUKAM
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832777
    m_Localized: "ILE CYKLI ZIMOWYCH SPALI\u0141A TWOJA ISKRA ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027072
    m_Localized: "JAK\u0104 ENERGI\u0118 WNIESZ DO NEXUS ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027073
    m_Localized: GDZIE TWOJA AURA JEST NAJsilniejsza W PRZESTRZENI ?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027074
    m_Localized: "TW\xD3J \u015ACIE\u017BKA ZOSTA\u0141A ZAPECZ\u0118TOWANA. WITAJ."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027075
    m_Localized: "Aura jest dzi\u015B milcz\u0105ca."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027076
    m_Localized: "M\u0118SKI"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027077
    m_Localized: "\u017BE\u0143SKI"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027078
    m_Localized: NEUTRALNY
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027079
    m_Localized: "SZUKAJ SWOJEGO KR\xD3LESTWA..."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027080
    m_Localized: "POTWIERD\u0179 WIEK"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027081
    m_Localized: "O\u015AWIETL MOJ\u0104 OBECNO\u015A\u0106"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027082
    m_Localized: SYMETRIA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027083
    m_Localized: "W POBLI\u017BU"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027084
    m_Localized: "\U0001F441\uFE0F Wyrocznia: Ta funkcja objawi si\u0119 w przysz\u0142ych
      cyklach (Beta)."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027085
    m_Localized: "G\u0141O\u015ANO\u015A\u0106 G\u0141\xD3WNA"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027086
    m_Localized: MUZYKA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027087
    m_Localized: EFEKTY
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027088
    m_Localized: "G\u0141OS WYROCZNI"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027089
    m_Localized: WYCISZ
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027090
    m_Localized: AKASZYCKI SKARBIEC
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027091
    m_Localized: "WYKRYTO SYMETRI\u0118"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221376
    m_Localized: "ODRZU\u0106"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221377
    m_Localized: TimeAura
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221378
    m_Localized: "POD JAKIM IMIENIEM NEXUS CI\u0118 POZNA ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221379
    m_Localized: OBJAW
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221380
    m_Localized: Co wnosisz do Nexus ?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221381
    m_Localized: "\u2692\uFE0F MATERIALNE"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221382
    m_Localized: "\u2726 ETERYCZNE"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221383
    m_Localized: "POTWIERD\u0179 OFERT\u0118"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221384
    m_Localized: "Tw\xF3j \u015Bcie\u017Cka zosta\u0142a zapiecz\u0119towana. Witaj."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415680
    m_Localized: ASPIRANT
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415681
    m_Localized: MISTRZ
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415682
    m_Localized: WYROCZNIA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415683
    m_Localized: "Linie Mocy s\u0105 wyr\xF3wnane."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415684
    m_Localized: "Eter jest tutaj turbulentny. Spr\xF3buj w innym miejscu."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415685
    m_Localized: "Oczekiwanie na \u015Bwi\u0119ty oddech..."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415686
    m_Localized: "Rozpoczynanie Rytua\u0142u Oblicza."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415687
    m_Localized: "Cienista \u015Bcie\u017Cka ujawnia twoj\u0105 prawdziw\u0105 esencj\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415688
    m_Localized: "Nieznane Kr\xF3lestwo"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415689
    m_Localized: Twoje dziedzictwo pozostaje niespisane...
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415690
    m_Localized: MANIFEST
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609984
    m_Localized: ZAMIAR
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609985
    m_Localized: KOMPAS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609986
    m_Localized: MEDITUJ Z ORACLE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609987
    m_Localized: "Opisz swoje umiej\u0119tno\u015Bci..."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609988
    m_Localized: "Wybierz sw\xF3j styl rezonansu"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609989
    m_Localized: Persona zaktualizowana.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609990
    m_Localized: MISTYK
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609991
    m_Localized: BIZNES
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609992
    m_Localized: "LU\u0179NY"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609993
    m_Localized: TECH
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609994
    m_Localized: "UPIECZ\u0118TOWANIE RYTUA\u0141U"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609995
    m_Localized: "ZATWIERD\u0179 DANE"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609996
    m_Localized: ZAPISZ PROFIL
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609997
    m_Localized: LECIMY!
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609998
    m_Localized: KONSULTACJA Z ORACLE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609999
    m_Localized: "Profil zsynchronizowany. Nexus jest zoptymalizowany dla Twojej
      obecno\u015Bci."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610000
    m_Localized: "Prosz\u0119 poda\u0107 sw\xF3j wiek."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610001
    m_Localized: "Wybierz swoj\u0105 to\u017Csamo\u015B\u0107 p\u0142ciow\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610002
    m_Localized: "Ustal swoj\u0105 stref\u0119 operacyjn\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610003
    m_Localized: "Od ilu lat rz\u0105dzisz na tej planecie?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610004
    m_Localized: "Bum! Twoja Aura jest gotowa, by l\u015Bni\u0107. Do zobaczenia
      w Nexusie!"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610005
    m_Localized: "Czysto\u015B\u0107"
    m_Metadata:
      m_Items: []
