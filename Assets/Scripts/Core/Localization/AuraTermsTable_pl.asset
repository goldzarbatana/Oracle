    m_Metadata:
      m_Items: []
  - m_Id: 25083740389998600
    m_Localized: WELLNESS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740389998601
    m_Localized: "SPO\u0141ECZNY"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740394192896
    m_Localized: "Pr\xF3bka rezonansu"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740394192897
    m_Localized: "MA\u0141Y"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740394192898
    m_Localized: "\u015AREDNI"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740394192899
    m_Localized: "DU\u017BY"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740398387200
    m_Localized: Oko postrzega wszystko.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740398387201
    m_Localized: DOPASUJ WZROK
    m_Metadata:
      m_Items: []
  - m_Id: 25083740398387202
    m_Localized: WYROCZNIA
    m_Metadata:
      m_Items: []
  - m_Id: 25636971566432256
    m_Localized: "ROZPOCZNIJ RYTUA\u0141"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569600
    m_Localized: Cyfrowy podpis
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569601
    m_Localized: Numer telefonu
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569602
    m_Localized: "Tw\xF3j numer"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569603
    m_Localized: ID_TELEFONU
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569604
    m_Localized: "Pr\xF3g wieczno\u015Bci czeka na twoj\u0105 obecno\u015B\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569605
    m_Localized: "Oczekiwanie na uwierzytelnienie u\u017Cytkownika."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569606
    m_Localized: "Drzwi s\u0105 otwarte, wchod\u017A!"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971616763904
    m_Localized: OCZEKIWANIE_NA_HANDSHAKE_KLIENTA...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958208
    m_Localized: "\u015Acie\u017Cka wymaga g\u0142\u0119bszej wibracji..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958209
    m_Localized: "Nieprawid\u0142owe dane. Nie osi\u0105gni\u0119to minimalnej d\u0142ugo\u015Bci."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958210
    m_Localized: "Ups, za kr\xF3tkie! Dodaj wi\u0119cej cyfr."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958211
    m_Localized: "ERR_NIEWYSTARCZAJ\u0104CA_D\u0141UGO\u015A\u0106_DANYCH"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958212
    m_Localized: "PRZYWO\u0141YWANIE SYMETRII..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958213
    m_Localized: "\u0141\u0104CZENIE Z SIECI\u0104..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958214
    m_Localized: "Czekaj, ju\u017C prawie jeste\u015Bmy..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958215
    m_Localized: "INICJOWANIE_US\u0141UG_RDZENIOWYCH..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958216
    m_Localized: "Gwiazdy nie sprzyjaj\u0105. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958217
    m_Localized: "Po\u0142\u0105czenie nieudane. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958218
    m_Localized: "Co\u015B posz\u0142o nie tak. Spr\xF3buj jeszcze raz!"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958219
    m_Localized: "B\u0141\u0104D_LIMITU_CZASU_HANDSHAKE"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958220
    m_Localized: "Kosmiczna ni\u0107 p\u0119k\u0142a. Po\u0142\u0105cz si\u0119 ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958221
    m_Localized: "B\u0142\u0105d krytyczny. Skontaktuj si\u0119 z pomoc\u0105 techniczn\u0105
      lub spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958222
    m_Localized: "Wielki b\u0142\u0105d! Spr\xF3buj jeszcze raz."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958223
    m_Localized: "KRYTYCZNY_WYJ\u0104TEK_SYSTEMU"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971650318336
    m_Localized: Rezonans duszy w eterze.
    m_Metadata:
      m_Items: []
  - m_Id: 25636971650318337
    m_Localized: "Oczekiwanie na \u015Bwi\u0119ty oddech..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512640
    m_Localized: "Inicjowanie protoko\u0142u weryfikacji..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512641
    m_Localized: "Czekaj chwil\u0119, sprawdzam..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512642
    m_Localized: OCZEKIWANIE_NA_PAKIETY...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512643
    m_Localized: "Twoja \u015Bcie\u017Cka jest zapiecz\u0119towana. Witaj."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512644
    m_Localized: SYSTEM_GOTOWY. INICJOWANIE...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512645
    m_Localized: "ZAPIECZ\u0118TUJ AUR\u0118"
    m_Metadata:
      m_Items: []
