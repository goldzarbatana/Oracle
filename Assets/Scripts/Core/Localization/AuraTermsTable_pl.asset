    m_Metadata:
      m_Items: []
  - m_Id: 316679749641
    m_Localized: "Rozpocznij Harmoni\u0119"
    m_Metadata:
      m_Items: []
  - m_Id: 316679749642
    m_Localized: "Rozwi\u0105zanie"
    m_Metadata:
      m_Items: []
  - m_Id: 316679749643
    m_Localized: Przebudzenie
    m_Metadata:
      m_Items: []
  - m_Id: 316683943936
    m_Localized: "\u015Awi\u0105tynia si\u0119 otwiera"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943941
    m_Localized: SUKCES
    m_Metadata:
      m_Items: []
  - m_Id: 316683943943
    m_Localized: "\u015Awi\u0105tynia czeka na twoj\u0105 obecno\u015B\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943944
    m_Localized: "Tw\xF3j sygna\u0142 rezonuje z jasno\u015Bci\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943945
    m_Localized: "Sygna\u0142 jest niejasny. Zweryfikuj sw\xF3j \u043D\u043E\u043C\u0435\u0440
      telefonu."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943946
    m_Localized: "Konwergencja si\u0119 rozpoczyna..."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943947
    m_Localized: "Witaj. \u015Awi\u0105tynia otwiera si\u0119 dla ciebie."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943948
    m_Localized: "Rytua\u0142 zosta\u0142 przerwany."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943949
    m_Localized: "Po\u0142\u0105czenie s\u0142abnie. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943950
    m_Localized: "Zak\u0142\xF3cenie \u0432 przep\u0142ywie. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943951
    m_Localized: Inicjowanie Harmonii...
    m_Metadata:
      m_Items: []
  - m_Id: 316683943952
    m_Localized: '{0} Horas'
    m_Metadata:
      m_Items: []
  - m_Id: 316683943953
    m_Localized: 'Horas: ${0} /godz'
    m_Metadata:
      m_Items: []
  - m_Id: 316683943954
    m_Localized: "Jak synchroniczna by\u0142a wymiana {0} Horas ?"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943955
    m_Localized: Misja dla poziomu {0}
    m_Metadata:
      m_Items: []
