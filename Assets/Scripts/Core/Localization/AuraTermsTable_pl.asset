    m_Metadata:
      m_Items: []
  - m_Id: 20624901246648320
    m_Localized: RESONUJ
    m_Metadata:
      m_Items: []
  - m_Id: 20931697802838016
    m_Localized: "\u015Acie\u017Cka wymaga d\u0142u\u017Cszego numeru..."
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809536
    m_Localized: OTWIERANIE PORTALU...
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809537
    m_Localized: "Portal pozostaje zamkni\u0119ty. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809538
    m_Localized: "Aura zamigota\u0142a. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 20974808302190592
    m_Localized: "Oblicze przybli\u017Ca Harmoni\u0119"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808327356416
    m_Localized: "Oblicze jest wymagane, aby przypiecz\u0119towa\u0107 t\u0119 Symetri\u0119"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550720
    m_Localized: ROLA / RANG
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550721
    m_Localized: "\u2726 Kana\u0142 Harmonii Otwarty \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550722
    m_Localized: Aktywny
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550723
    m_Localized: "Okno 24h zosta\u0142o zamkni\u0119te."
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550724
    m_Localized: "\u2726 Harmonia zamkni\u0119ta spokojnie. \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550725
    m_Localized: "\u2B21 Zaproponowa\u0142e\u015B {0} Horas"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550726
    m_Localized: 'Propozycja: {0} Horas'
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550727
    m_Localized: "\u2B21 {0} Horas zaakceptowane. Harmonia ro\u015Bnie."
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550728
    m_Localized: "\u2B21 Propozycja odrzucona."
    m_Metadata:
      m_Items: []
