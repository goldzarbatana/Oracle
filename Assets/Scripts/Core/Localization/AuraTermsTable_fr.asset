      m_Items: []
  - m_Id: 25083740373221381
    m_Localized: "\u2692\uFE0F MAT\xC9RIEL"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221382
    m_Localized: "\u2726 \xC9TH\xC9R\xC9"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221383
    m_Localized: CONFIRMER L'OFFRE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221384
    m_Localized: "Votre chemin est scell\xE9. Bienvenue."
