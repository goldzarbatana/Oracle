      m_Items: []
  - m_Id: 25083740377415690
    m_Localized: MANIFESTE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609984
    m_Localized: INTENTION
    m_Metadata:
      m_Items: []
