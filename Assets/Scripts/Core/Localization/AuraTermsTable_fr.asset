    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253759
    m_Localized: TENIR POUR ALIGNER
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253760
    m_Localized: FUSIONNEZ VOTRE ESPRIT
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253761
    m_Localized: TENIR POUR CONFIRMER LE PARTENARIAT
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253762
    m_Localized: MAINTENIR LA LIAISON MONTANTE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253763
    m_Localized: SAGESSE DE L'ORACLE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836608
    m_Localized: "MUMURES \xC9TH\xC9R\xC9S"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836609
    m_Localized: "APER\xC7US EX\xC9CUTIFS"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836610
    m_Localized: "ANALYSE DE C\u0152UR"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836611
    m_Localized: "Les flux cosmiques sont turbulents. R\xE9essayez plus tard."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836612
    m_Localized: "Les \xE9toiles sont voil\xE9es d'ombre. Reconnectez-vous quand
      les courants s'\xE9claircissent."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836613
    m_Localized: "Connexion r\xE9seau instable. Veuillez r\xE9initialiser la consultation
      plus tard."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836614
    m_Localized: "Perte de paquets d\xE9tect\xE9e dans l'\xC9ther. \xC9chec de la
      poign\xE9e de main. R\xE9essayez plus tard."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836615
    m_Localized: VISION
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836616
    m_Localized: SANCTUAIRE DE L'ORACLE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836617
    m_Localized: QUITTER LE SILENCE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030912
    m_Localized: "Le silence est absolu aujourd'hui. R\xE9essayez plus tard."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030913
    m_Localized: "Choisissez votre style de r\xE9sonance."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030914
    m_Localized: "Quel chemin votre \xE2me murmure-t-elle ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030915
    m_Localized: "S\xE9lectionnez votre ton de communication professionnel."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030916
    m_Localized: Configurer le protocole d'interaction.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030917
    m_Localized: Comment devrions-nous parler ?
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030918
    m_Localized: "Votre vibration a \xE9t\xE9 r\xE9align\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030919
    m_Localized: "Param\xE8tres du profil synchronis\xE9s avec succ\xE8s."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030920
    m_Localized: "Protocole d'interface mis \xE0 jour."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030921
    m_Localized: Compris ! Je change de style maintenant.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030922
    m_Localized: "Entrez dans le flux de la causalit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030923
    m_Localized: "Initialisation du module d'analyse pr\xE9dictive."
    m_Metadata:
      m_Items: []
