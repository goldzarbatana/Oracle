  - m_Id: 316683943941
    m_Localized: "SUCC\xC8S"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943943
    m_Localized: "Le temple attend votre pr\xE9sence."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943944
    m_Localized: "Votre signal r\xE9sonne avec clart\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943945
    m_Localized: "Le signal n'est pas clair. Veuillez v\xE9rifier votre num\xE9ro
      de t\xE9l\xE9phone."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943946
    m_Localized: La convergence commence...
    m_Metadata:
      m_Items: []
  - m_Id: 316683943947
    m_Localized: Bienvenue. Le temple s'ouvre pour vous.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943948
    m_Localized: "Le rituel a \xE9t\xE9 interrompu."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943949
    m_Localized: "La connexion faiblit. Veuillez r\xE9essayer."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943950
    m_Localized: "Une perturbation dans le flux. Veuillez r\xE9essayer."
    m_Metadata:
      m_Items: []
