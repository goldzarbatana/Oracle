  - m_Id: 25732953956253756
    m_Localized: Essenz
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253757
    m_Localized: Einnahmen
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253758
    m_Localized: Zyklen
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253759
    m_Localized: HALTEN ZUM AUSRICHTEN
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253760
    m_Localized: VERSCHMELZE DEINEN GEIST
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253761
    m_Localized: "HALTEN ZUM BEST\xC4TIGEN DER PARTNERSCHAFT"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253762
    m_Localized: UPLINK AUFRECHTERHALTEN
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253763
    m_Localized: ORAKEL-WEISHEIT
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836608
    m_Localized: "\xC4THERISCHES FL\xDCSTERN"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836609
    m_Localized: EXECUTIVE INSIGHTS
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836610
    m_Localized: KERNANALYSE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836611
    m_Localized: "Die kosmischen Str\xF6me sind turbulent. Versuche es sp\xE4ter
      noch einmal."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836612
    m_Localized: "Die Sterne sind in Schatten geh\xFCllt. Verbinde dich erneut, wenn
      die Str\xF6mungen klar sind."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836613
    m_Localized: "Netzwerkverbindung instabil. Bitte Beratungsgespr\xE4ch sp\xE4ter
      erneut einleiten."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836614
    m_Localized: "Paketverlust im \xC4ther festgestellt. Handshake fehlgeschlagen.
      Sp\xE4ter versuchen."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836615
    m_Localized: SICHT
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836616
    m_Localized: ORAKEL-HEILIGTUM
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836617
    m_Localized: STILLE VERLASSEN
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030912
    m_Localized: "Die Stille ist heute absolut. Versuche es sp\xE4ter noch einmal."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030913
    m_Localized: "W\xE4hle deinen Resonanzstil."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030914
    m_Localized: "Welchen Weg fl\xFCstert deine Seele?"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030915
    m_Localized: "W\xE4hlen Sie Ihren professionellen Kommunikationston."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030916
    m_Localized: Interaktionsprotokoll konfigurieren.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030917
    m_Localized: Wie sollen wir reden?
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030918
    m_Localized: Deine Schwingung wurde neu ausgerichtet.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030919
    m_Localized: Profileinstellungen erfolgreich synchronisiert.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030920
    m_Localized: Schnittstellenprotokoll aktualisiert.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030921
    m_Localized: Verstanden! Wechsle jetzt den Stil.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030922
    m_Localized: "Tritt in den Strom der Kausalit\xE4t."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030923
    m_Localized: "Pr\xE4diktives Analysemodul wird gestartet."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030924
    m_Localized: Zugriff auf neuronale Metadaten.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030925
    m_Localized: KOMPASS
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030926
    m_Localized: CHRONIKEN
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030927
    m_Localized: NETZWERK
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030928
    m_Localized: DATENSTROM
    m_Metadata:
      m_Items: []
