    m_Localized: "ANGEBOT BEST\xC4TIGEN"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221384
    m_Localized: Dein Weg ist versiegelt. Willkommen.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415680
    m_Localized: "ANW\xC4RTER"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415681
    m_Localized: MEISTER
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415682
    m_Localized: ORAKEL
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415683
    m_Localized: Die Ley-Linien sind ausgerichtet.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415684
    m_Localized: "Der \xC4ther ist hier turbulent. Versuche es an einem anderen Ort."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415685
    m_Localized: Warten auf den heiligen Atem...
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415686
    m_Localized: Beginn des Antlitz-Rituals.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415687
    m_Localized: Der Schattenpfad offenbart dein wahres Wesen.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415688
    m_Localized: Unbekanntes Reich
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415689
    m_Localized: "Dein Verm\xE4chtnis ist noch ungeschrieben..."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415690
    m_Localized: MANIFEST
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609984
    m_Localized: INTENTION
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609985
    m_Localized: KOMPASS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609986
    m_Localized: MIT DEM ORakel MEDITIEREN
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609987
    m_Localized: "Beschreibe deine F\xE4higkeiten..."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609988
    m_Localized: "W\xE4hle deinen Resonanzstil"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609989
    m_Localized: Persona aktualisiert.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609990
    m_Localized: MYSTISCH
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609991
    m_Localized: BUSINESS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609992
    m_Localized: CASUAL
    m_Metadata:
      m_Items: []
