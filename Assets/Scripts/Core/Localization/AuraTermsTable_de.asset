    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832774
    m_Localized: DEINE AKTUELLE AURA...
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832775
    m_Localized: MEINE GABEN
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832776
    m_Localized: ICH SUCHE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832777
    m_Localized: WIE VIELE WINTERZYKLEN HAT DEIN FUNKE GEBRANNT ?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027072
    m_Localized: WELCHE ENERGIE BRINGST DU IN DEN NEXUS ?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027073
    m_Localized: "WO IST DEINE AURA IM RAUM AM ST\xC4RKSTEN ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027074
    m_Localized: DEIN WEG IST VERSIEGELT. WILLKOMMEN.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027075
    m_Localized: Die Aura schweigt heute.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027076
    m_Localized: MASKULIN
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027077
