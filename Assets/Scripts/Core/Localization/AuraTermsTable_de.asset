    m_Localized: TECH
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609994
    m_Localized: DAS RITUAL VERSIEGELN
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609995
    m_Localized: "DATEN \xDCBERTRAGEN"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609996
    m_Localized: PROFIL SPEICHERN
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609997
    m_Localized: AUF GEHT'S!
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609998
    m_Localized: DEN ORakel BEFRAGEN
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609999
    m_Localized: "Profil synchronisiert. Der Nexus ist f\xFCr Ihre Pr\xE4senz optimiert."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610000
    m_Localized: Bitte geben Sie Ihr Alter an.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610001
    m_Localized: "W\xE4hlen Sie Ihre Geschlechtsidentit\xE4t."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610002
    m_Localized: Legen Sie Ihre Betriebszone fest.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610003
    m_Localized: Seit wie vielen Jahren rockst du schon diesen Planeten?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381610004
    m_Localized: Boom! Deine Aura ist bereit zu strahlen. Wir sehen uns im Nexus!
