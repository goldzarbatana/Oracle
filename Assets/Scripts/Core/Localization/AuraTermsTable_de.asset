  - m_Id: 20624901238259712
    m_Localized: "MEISTER IN DER N\xC4HE"
    m_Metadata:
      m_Items: []
  - m_Id: 20624901246648320
    m_Localized: RESONIEREN
    m_Metadata:
      m_Items: []
  - m_Id: 20931697802838016
    m_Localized: "Der Pfad erfordert eine l\xE4ngere Nummer..."
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809536
    m_Localized: "PORTAL WIRD GE\xD6FFNET..."
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809537
    m_Localized: Das Portal bleibt geschlossen. Versuche es erneut.
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809538
    m_Localized: Die Aura flackerte. Bitte versuche es erneut.
    m_Metadata:
      m_Items: []
  - m_Id: 20974808302190592
    m_Localized: "Ein Antlitz bringt Harmonie n\xE4her"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808327356416
    m_Localized: Ein Antlitz ist erforderlich, um diese Symmetrie zu besiegeln
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550720
    m_Localized: ROLLE / RANG
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550721
    m_Localized: "\u2726 Harmony-Kanal Er\xF6ffnet \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550722
    m_Localized: Aktiv
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550723
    m_Localized: Das 24-Stunden-Fenster ist abgelaufen.
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550724
    m_Localized: "\u2726 Harmonie friedlich beendet. \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550725
    m_Localized: "\u2B21 Sie bieten {0} Horas an"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550726
    m_Localized: 'Angebot: {0} Horas'
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550727
    m_Localized: "\u2B21 {0} Horas akzeptiert. Harmonie w\xE4chst."
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550728
    m_Localized: "\u2B21 Angebot abgelehnt."
    m_Metadata:
