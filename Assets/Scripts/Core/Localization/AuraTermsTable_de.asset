    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027084
    m_Localized: "\U0001F441\uFE0F Orakel: Diese Funktion wird sich in zuk\xFCnftigen
      Zyklen manifestieren (Beta)."
    m_Metadata:
      m_Items: []
