  - m_Id: 316679749641
    m_Localized: Einweihung der Harmonie
    m_Metadata:
      m_Items: []
  - m_Id: 316679749642
    m_Localized: "Aufl\xF6sung"
    m_Metadata:
      m_Items: []
  - m_Id: 316679749643
    m_Localized: Erwachen
    m_Metadata:
      m_Items: []
  - m_Id: 316683943936
    m_Localized: "Der Tempel \xF6ffnet sich"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943941
    m_Localized: ERFOLG
    m_Metadata:
      m_Items: []
  - m_Id: 316683943943
    m_Localized: Der Tempel erwartet deine Anwesenheit.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943944
    m_Localized: Dein Signal schwingt klar.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943945
    m_Localized: "Das Signal ist unklar. Bitte \xFCberpr\xFCfe deine Telefonnummer."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943946
    m_Localized: Die Konvergenz beginnt...
    m_Metadata:
      m_Items: []
  - m_Id: 316683943947
    m_Localized: "Willkommen. Der Tempel \xF6ffnet sich f\xFCr dich."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943948
    m_Localized: Das Ritual wurde unterbrochen.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943949
    m_Localized: Die Verbindung bricht ab. Bitte versuche es erneut.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943950
    m_Localized: "Eine St\xF6rung im Fluss. Bitte versuche es erneut."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943951
    m_Localized: Harmonie wird eingeleitet...
    m_Metadata:
      m_Items: []
  - m_Id: 316683943952
    m_Localized: '{0} Horas'
    m_Metadata:
      m_Items: []
  - m_Id: 316683943953
    m_Localized: 'Horas: ${0} /Std'
    m_Metadata:
      m_Items: []
  - m_Id: 316683943954
    m_Localized: Wie synchron war der Austausch von {0} Horas ?
    m_Metadata:
      m_Items: []
  - m_Id: 316683943955
    m_Localized: "Mission f\xFCr Level {0}"
    m_Metadata:
      m_Items: []
