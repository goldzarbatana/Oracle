    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030933
    m_Localized: "DANI\u015EMAN"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030934
    m_Localized: "ARAY\xDCZ"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030935
    m_Localized: "RUHUNUZU REZONANSA GET\u0130R\u0130N"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030936
    m_Localized: "ZAMAN HAZ\u0130NES\u0130"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030937
    m_Localized: VARLIK DEPOSU
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030938
    m_Localized: "\u015E\u0130FREL\u0130 VER\u0130 MAHZEN\u0130"
    m_Metadata:
      m_Items: []
