    m_Metadata:
      m_Items: []
  - m_Id: 316679749643
    m_Localized: "Uyan\u0131\u015F"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943936
    m_Localized: "Tap\u0131nak A\xE7\u0131l\u0131yor"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943941
    m_Localized: "BA\u015EARI"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943943
    m_Localized: "Tap\u0131nak sizi bekliyor."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943944
    m_Localized: "Sinyaliniz netlikle rezonans yap\u0131yor."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943945
    m_Localized: "Sinyal belirsiz. L\xFCtfen telefon numaran\u0131z\u0131 do\u011Frulay\u0131n."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943946
    m_Localized: "Yak\u0131nsama ba\u015Fl\u0131yor..."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943947
    m_Localized: "Ho\u015F geldiniz. Tap\u0131nak sizin i\xE7in a\xE7\u0131l\u0131yor."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943948
    m_Localized: "Rit\xFCel kesintiye u\u011Frad\u0131."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943949
    m_Localized: "Ba\u011Flant\u0131 zay\u0131fl\u0131yor. L\xFCtfen tekrar deneyin."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943950
    m_Localized: "Ak\u0131\u015Fta bir bozulma. L\xFCtfen tekrar deneyin."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943951
    m_Localized: "Uyum ba\u015Flat\u0131l\u0131yor..."
    m_Metadata:
      m_Items: []
