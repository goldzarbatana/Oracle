    m_Localized: MANTENER UPLINK
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253763
    m_Localized: "SABIDUR\xCDA DEL OR\xC1CULO"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836608
    m_Localized: "SUSURROS ET\xC9REOS"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836609
    m_Localized: PERSPECTIVAS EJECUTIVAS
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836610
    m_Localized: "AN\xC1LISIS DE NUCLEO"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836611
    m_Localized: "Los flujos c\xF3smicos son turbulentos. Intenta m\xE1s tarde."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836612
    m_Localized: "Las estrellas est\xE1n veladas en sombras. Reconecta cuando las
      corrientes se aclaren."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836613
    m_Localized: "Conexi\xF3n inestable. Reinicia la consulta m\xE1s tarde."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836614
    m_Localized: "P\xE9rdida de paquetes detectada. Error de protocolo. Intenta m\xE1s
      tarde."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836615
    m_Localized: "VISI\xD3N"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836616
    m_Localized: "SANTUARIO DEL OR\xC1CULO"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836617
    m_Localized: SALIR DEL SILENCIO
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030912
    m_Localized: "El silencio es absoluto hoy. Intenta m\xE1s tarde."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030913
    m_Localized: Elige tu estilo de resonancia.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030914
    m_Localized: "\xBFQu\xE9 camino susurra tu alma?"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030915
    m_Localized: "Selecciona tu tono de comunicaci\xF3n profesional."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030916
    m_Localized: "Configurar protocolo de interacci\xF3n."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030917
    m_Localized: "\xBFC\xF3mo deber\xEDamos hablar?"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030918
    m_Localized: "Tu vibraci\xF3n ha sido realineada."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030919
    m_Localized: "Ajustes de perfil sincronizados con \xE9xito."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030920
    m_Localized: Protocolo de interfaz actualizado.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030921
    m_Localized: "\xA1Entendido! Cambiando estilo."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030922
    m_Localized: Entra en el flujo de la causalidad.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030923
    m_Localized: "Iniciando m\xF3dulo de an\xE1lisis predictivo."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030924
    m_Localized: Accediendo a metadatos neuronales.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030925
    m_Localized: "BR\xDAJULA"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030926
    m_Localized: "CR\xD3NICAS"
    m_Metadata:
      m_Items: []
