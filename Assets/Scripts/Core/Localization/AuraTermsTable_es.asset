  - m_Id: 25732953956253739
    m_Localized: ALMACENAMIENTO DE DATOS
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253740
    m_Localized: "MIRADA AL \xC9TER"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253741
    m_Localized: BUSCANDO ECOS DESTINADOS...
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253742
    m_Localized: "\xA1SIMETR\xCDA MANIFESTADA!"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253743
    m_Localized: "\xA1OBJETIVO ADQUIRIDO!"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253744
    m_Localized: "\xA1NODOS CONECTADOS!"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253745
    m_Localized: "CANALIZAR \u2728"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253746
    m_Localized: "RECOMENDAR \U0001F91D"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253747
    m_Localized: "VINCULAR \U0001F517"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253748
    m_Localized: "ME GUSTA \u2764\uFE0F"
    m_Metadata:
      m_Items: []
