    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027072
    m_Localized: "\xBFQU\xC9 ENERG\xCDA TRAES AL NEXUS ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027073
    m_Localized: "\xBF\u0414\xD3NDE ES M\xC1S FUERTE TU AURA EN EL ESPACIO ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027074
    m_Localized: "TU CAMINO EST\xC1 SELLADO. BIENVENIDO."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027075
