  - m_Id: 25083740394192897
    m_Localized: "PEQUE\xD1O"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740394192898
    m_Localized: MEDIO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740394192899
    m_Localized: GRANDE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740398387200
    m_Localized: El Ojo lo percibe todo.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740398387201
    m_Localized: ALINEAR LA VISTA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740398387202
    m_Localized: "OR\xC1CULO"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971566432256
    m_Localized: INICIAR RITUAL
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569600
    m_Localized: Firma digital
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569601
    m_Localized: "N\xFAmero de tel\xE9fono"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569602
    m_Localized: "Tu n\xFAmero"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569603
    m_Localized: "ID_TEL\xC9FONO"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569604
    m_Localized: El umbral de la eternidad espera tu presencia.
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569605
    m_Localized: "Esperando autenticaci\xF3n de usuario."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971612569606
    m_Localized: "\xA1La puerta est\xE1 abierta, entra!"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971616763904
    m_Localized: ESPERANDO_HANDSHAKE_CLIENTE...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958208
    m_Localized: "El camino requiere una vibraci\xF3n m\xE1s profunda..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958209
    m_Localized: "Entrada no v\xE1lida. No se cumple la longitud m\xEDnima."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958210
    m_Localized: "\xA1Uy, muy corto! A\xF1ade algunos n\xFAmeros m\xE1s."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958211
    m_Localized: ERR_LONGITUD_ENTRADA_INSUFICIENTE
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958212
    m_Localized: "INVOCANDO SIMETR\xCDA..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958213
    m_Localized: CONECTANDO A LA RED...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958214
    m_Localized: "\xA1Espera, ya casi estamos!"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958215
    m_Localized: "INICIALIZANDO_SERVICIOS_N\xDACLEO..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958216
    m_Localized: "Las estrellas est\xE1n desalineadas. Int\xE9ntalo de nuevo."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958217
    m_Localized: "Conexi\xF3n fallida. Por favor intenta de nuevo."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958218
    m_Localized: "Algo sali\xF3 mal. \xA1Int\xE9ntalo de nuevo!"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958219
    m_Localized: TIMEOUT_HANDSHAKE
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958220
    m_Localized: "El hilo c\xF3smico se rompi\xF3. Reconecta."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958221
    m_Localized: "Error cr\xEDtico. Contacta al soporte o reintenta."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958222
    m_Localized: "\xA1Gran error aqu\xED! Int\xE9ntalo una vez m\xE1s."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971620958223
    m_Localized: "EXCEPCI\xD3N_CR\xCDTICA_SISTEMA"
    m_Metadata:
      m_Items: []
  - m_Id: 25636971650318336
    m_Localized: "Resonancia del alma en el \xE9ter."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971650318337
    m_Localized: Esperando el aliento sagrado...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512640
    m_Localized: "Iniciando protocolo de verificaci\xF3n..."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512641
    m_Localized: Espera, estoy revisando...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512642
    m_Localized: ESPERANDO_PAQUETES_DE_DATOS...
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512643
    m_Localized: "Tu camino est\xE1 sellado. Bienvenido."
    m_Metadata:
      m_Items: []
  - m_Id: 25636971654512644
