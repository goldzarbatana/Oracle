    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253759
    m_Localized: MANTENER PARA ALINEAR
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253760
    m_Localized: "FUSIONA TU ESP\xCDRITU"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253761
    m_Localized: MANTENER PARA CONFIRMAR ALIANZA
    m_Metadata:
