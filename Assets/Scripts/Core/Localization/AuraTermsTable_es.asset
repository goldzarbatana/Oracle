    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809536
    m_Localized: ABRIENDO EL PORTAL...
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809537
    m_Localized: "El portal permanece cerrado. Int\xE9ntalo de nuevo."
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809538
