    m_Localized: 'Throughput: {0} Op/sec'
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253756
    m_Localized: Essenza
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253757
    m_Localized: Ricavo
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253758
    m_Localized: Cicli
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253759
    m_Localized: TIENI PER ALLINEARE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253760
    m_Localized: FONDETE IL VOSTRO SPIRITO
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253761
    m_Localized: TIENI PER CONFERMARE LA PARTNERSHIP
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253762
    m_Localized: MANTIENI UPLINK
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253763
    m_Localized: SAGGEZZA DELL'ORACOLO
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836608
    m_Localized: SUSSURRI ETEREI
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836609
    m_Localized: APPROFONDIMENTI ESECUTIVI
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836610
    m_Localized: ANALISI CORE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836611
    m_Localized: "I flussi cosmici sono turbolenti. Riprova pi\xF9 tardi."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836612
    m_Localized: Le stelle sono velate d'ombra. Riconnettiti quando le correnti si
      schiariscono.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836613
    m_Localized: "Connessione instabile. Riavvia la consultazione pi\xF9 tardi."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836614
    m_Localized: Rilevata perdita di pacchetti nell'Etere. Handshake fallito. Riprova.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836615
    m_Localized: VISIONE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836616
    m_Localized: SANTUARIO DELL'ORACOLO
    m_Metadata:
      m_Items: []
  - m_Id: 25732953968836617
    m_Localized: ESCI DAL SILENZIO
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030912
    m_Localized: "Il silenzio \xE8 assoluto oggi. Riprova pi\xF9 tardi."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030913
    m_Localized: Scegli il tuo stile di risonanza.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030914
    m_Localized: Quale sentiero sussurra la tua anima?
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030915
    m_Localized: Seleziona il tuo tono di comunicazione professionale.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030916
    m_Localized: Configura il protocollo di interazione.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030917
    m_Localized: Come dovremmo parlare?
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030918
    m_Localized: "La tua vibrazione \xE8 stata riallineata."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030919
    m_Localized: Impostazioni del profilo sincronizzate con successo.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030920
    m_Localized: Protocollo di interfaccia aggiornato.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030921
    m_Localized: Ricevuto! Cambio stile ora.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030922
    m_Localized: "Entra nel flusso della causalit\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030923
    m_Localized: Inizializzazione del modulo di analisi predittiva.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030924
    m_Localized: Accesso ai metadati neurali.
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030925
    m_Localized: BUSSOLA
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030926
    m_Localized: CRONACHE
    m_Metadata:
      m_Items: []
  - m_Id: 25732953973030927
    m_Localized: RETE
    m_Metadata:
      m_Items: []
