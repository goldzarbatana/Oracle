  - m_Id: 25732953956253750
    m_Localized: "APPROVATO \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253751
    m_Localized: "COLLEGATO \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 25732953956253752
    m_Localized: "MI PIACE \u2726"
    m_Metadata:
      m_Items: []
