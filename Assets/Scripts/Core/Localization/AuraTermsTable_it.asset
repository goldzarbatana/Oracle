  - m_Id: 20624901238259712
    m_Localized: MAESTRI NELLE VICINANZE
    m_Metadata:
      m_Items: []
  - m_Id: 20624901246648320
    m_Localized: RISONA
    m_Metadata:
      m_Items: []
  - m_Id: 20931697802838016
    m_Localized: "Il percorso richiede un numero pi\xF9 lungo..."
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809536
    m_Localized: APERTURA DEL PORTALE...
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809537
    m_Localized: Il portale rimane chiuso. Riprova.
    m_Metadata:
      m_Items: []
  - m_Id: 20931697823809538
    m_Localized: "L'Aura tremol\xF2. Per favore riprova."
    m_Metadata:
      m_Items: []
  - m_Id: 20974808302190592
    m_Localized: Un Visage avvicina l'Armonia
    m_Metadata:
      m_Items: []
  - m_Id: 20974808327356416
    m_Localized: "\xC8 richiesto un Visage per sigillare questa Simmetria"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550720
    m_Localized: RUOLO / RANGO
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550721
    m_Localized: "\u2726 Canale Armonia Aperto \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550722
    m_Localized: Attivo
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550723
    m_Localized: "La finestra di 24h si \xE8 chiusa."
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550724
    m_Localized: "\u2726 Armonia chiusa in pace. \u2726"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550725
    m_Localized: "\u2B21 Hai proposto {0} Horas"
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550726
    m_Localized: 'Proposta: {0} Horas'
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550727
    m_Localized: "\u2B21 {0} Horas accettati. L'Armonia cresce."
    m_Metadata:
      m_Items: []
  - m_Id: 20974808331550728
    m_Localized: "\u2B21 Proposta rifiutata."
    m_Metadata:
      m_Items: []
