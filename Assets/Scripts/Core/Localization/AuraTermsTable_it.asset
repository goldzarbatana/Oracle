    m_Metadata:
      m_Items: []
  - m_Id: 16385424668065794
    m_Localized: Lascia una parola di gratitudine.
    m_Metadata:
      m_Items: []
  - m_Id: 16385424668065795
    m_Localized: "L'eredit\xE0 del Maestro"
