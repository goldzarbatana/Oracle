    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336833
    m_Localized: PROSPETTIVE
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336834
    m_Localized: "CHI C'\xC8?"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336835
    m_Localized: SCANNER
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336836
    m_Localized: PRONTO PER IL NETWORKING
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336837
    m_Localized: "CHI C'\xC8 IN GIRO?"
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336838
    m_Localized: SCANSIONE FREQUENZE
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336839
    m_Localized: RICERCA DI ASSET...
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336840
    m_Localized: CERCO VIBE...
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336841
    m_Localized: PARSING DATI SPETTRALI...
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336842
    m_Localized: CONNETTI
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336843
    m_Localized: DI' CIAO
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336844
    m_Localized: UPLINK
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336845
    m_Localized: LA VOCE MISTICA
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336846
    m_Localized: LA VOCE BUSINESS
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336847
    m_Localized: LA VOCE CASUAL
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336848
    m_Localized: LA VOCE TECH
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336849
    m_Localized: DEFINISCI LE COMPETENZE CHIAVE
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336850
    m_Localized: MOSTRA IL TUO VIBE
    m_Metadata:
      m_Items: []
  - m_Id: 24516584233336851
    m_Localized: CONFIGURA LA MATRICE DEGLI ATTRIBUTI
    m_Metadata:
      m_Items: []
  - m_Id: 24516584237531136
    m_Localized: PRONTO!
    m_Metadata:
      m_Items: []
  - m_Id: 25083740322889728
    m_Localized: IMPOSTAZIONI NEXUS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832768
    m_Localized: VOLUME MASTER
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832769
    m_Localized: MUSICA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832770
    m_Localized: EFFETTI (SFX)
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832771
    m_Localized: AMBIENCE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832772
    m_Localized: MUTO TOTALE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832773
    m_Localized: BENVENUTI NEL NEXUS
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832774
    m_Localized: LA TUA AURA ATTUALE...
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832775
    m_Localized: I MIEI DONI
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832776
    m_Localized: CERCO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740364832777
    m_Localized: QUANTI CICLI INVERNALI HA BRUCIATO LA TUA SCINTILLA ?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027072
    m_Localized: QUALE ENERGIA PORTI AL NEXUS ?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027073
    m_Localized: "DOVE \xC8 PI\xD9 FORTE LA TUA AURA NELLO SPAZIO ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027074
    m_Localized: "IL TUO CAMMINO \xC8 SIGILLATO. BENVENUTO."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027075
    m_Localized: "L'Aura \xE8 silenziosa oggi."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027076
    m_Localized: MASCHILE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027077
    m_Localized: FEMMINILE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027078
    m_Localized: NEUTRALE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027079
    m_Localized: CERCA IL TUO REGNO...
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027080
    m_Localized: "CONFERMA ET\xC0"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027081
    m_Localized: ILLUMINA LA MIA PRESENZA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027082
    m_Localized: SIMMETRIA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027083
    m_Localized: VICINI
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027084
    m_Localized: "\U0001F441\uFE0F Oracolo: Questa funzione si manifester\xE0 nei
      cicli futuri (Beta)."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027085
    m_Localized: VOLUME GENERALE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027086
    m_Localized: MUSICA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027087
    m_Localized: EFFETTI
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027088
    m_Localized: VOCE DELL'ORACOLO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027089
    m_Localized: MUTO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027090
    m_Localized: IL VOLTO AKASHICO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740369027091
    m_Localized: SIMMETRIA RILEVATA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221376
    m_Localized: DECLINA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221377
    m_Localized: TimeAura
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221378
    m_Localized: "CON QUALE NOME TI CONOSCER\xC0 IL NEXUS ?"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221379
    m_Localized: RIVELA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221380
    m_Localized: Cosa porti al Nexus ?
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221381
    m_Localized: "\u2692\uFE0F MATERIALE"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221382
    m_Localized: "\u2726 ETEREO"
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221383
    m_Localized: CONFERMA OFFERTA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740373221384
    m_Localized: "Il tuo cammino \xE8 sigillato. Benvenuto."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415680
    m_Localized: ASPIRANTE
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415681
    m_Localized: MAESTRO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415682
    m_Localized: ORACOLO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415683
    m_Localized: Le Linee di Forza sono allineate.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415684
    m_Localized: "L'etere \xE8 turbolento qui. Prova un altro punto."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415685
    m_Localized: In attesa del respiro sacro...
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415686
    m_Localized: Inizio del Rituale del Volto.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415687
    m_Localized: Il cammino dell'ombra rivela la tua vera essenza.
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415688
    m_Localized: Regno Sconosciuto
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415689
    m_Localized: "La tua eredit\xE0 resta non scritta..."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740377415690
    m_Localized: MANIFESTO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609984
    m_Localized: INTENTO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609985
    m_Localized: BUSSOLA
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609986
    m_Localized: MEDITA CON L'ORACOLO
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609987
    m_Localized: "Descrivi le tue abilit\xE0..."
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609988
    m_Localized: Scegli il tuo stile di risonanza
    m_Metadata:
      m_Items: []
  - m_Id: 25083740381609989
    m_Localized: Persona aggiornata.
    m_Metadata:
