  - m_Id: 316683943936
    m_Localized: Il Tempio si apre
    m_Metadata:
      m_Items: []
  - m_Id: 316683943941
    m_Localized: SUCCESSO
    m_Metadata:
      m_Items: []
  - m_Id: 316683943943
    m_Localized: Il tempio attende la tua presenza.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943944
    m_Localized: Il tuo segnale risuona con chiarezza.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943945
    m_Localized: "Il segnale non \xE8 chiaro. Verifica il tuo numero di telefono."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943946
    m_Localized: La convergenza inizia...
    m_Metadata:
      m_Items: []
  - m_Id: 316683943947
    m_Localized: Benvenuto. Il tempio si apre per te.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943948
    m_Localized: "Il rituale \xE8 stato interrotto."
    m_Metadata:
      m_Items: []
  - m_Id: 316683943949
    m_Localized: La connessione vacilla. Per favore riprova.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943950
    m_Localized: Un disturbo nel flusso. Per favore riprova.
    m_Metadata:
      m_Items: []
  - m_Id: 316683943951
    m_Localized: Iniziando l'Armonia...
    m_Metadata:
      m_Items: []
  - m_Id: 316683943952
    m_Localized: '{0} Horas'
    m_Metadata:
      m_Items: []
  - m_Id: 316683943953
    m_Localized: 'Horas: ${0} /ora'
    m_Metadata:
      m_Items: []
  - m_Id: 316683943954
    m_Localized: "Quanto \xE8 stato sincrono lo scambio di {0} Horas ?"
    m_Metadata:
      m_Items: []
  - m_Id: 316683943955
    m_Localized: Missione per il livello {0}
    m_Metadata:
      m_Items: []
